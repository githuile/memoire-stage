<!-- DHCPACK: device got an IP (connection complete) -->
<decoder name="ubiquiti-dhcp-ack">
  <prematch>dnsmasq-dhcp</prematch>
  <regex>DHCPACK\((\w+)\)\s+(\S+)\s+(\S+)\s+(\S+)</regex>
  <order>interface, srcip, srcmac, hostname</order>
</decoder>


<!-- DHCP Windows -->
<decoder name="ms-dhcp-ipv4-fields">
  <parent>ms-dhcp-ipv4</parent>
  <regex type="pcre2">^(\d+),[\d/]+,[\d:]+,[^,]+,([\d.]+),([^,]*),([A-F0-9]{12})</regex>
  <order>id,srcip,hostname,mac</order>
</decoder>